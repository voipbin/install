# RTPEngine Docker Compose - generated by Ansible
# DO NOT EDIT MANUALLY - Changes will be overwritten

services:
  # RTPEngine media proxy daemon
  rtpengine:
    image: ${RTPENGINE_IMAGE}
    container_name: rtpengine
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - SYS_NICE
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    init: true
    stop_grace_period: 30s
    environment:
      - RTPENGINE_INTERFACE_MODE
      - RTPENGINE_INTERFACE
      - RTPENGINE_LISTEN_HTTP
      - RTPENGINE_LISTEN_NG
      - RTPENGINE_LISTEN_CLI
      - RTPENGINE_PORT_MIN
      - RTPENGINE_PORT_MAX
      - RTPENGINE_TIMEOUT
      - RTPENGINE_SILENT_TIMEOUT
      - RTPENGINE_LOG_LEVEL
      - RTPENGINE_LOG_FACILITY
      - RTPENGINE_NUM_THREADS
      - RTPENGINE_DELETE_DELAY
      - RTPENGINE_TOS
      - RTPENGINE_HOMER_SERVER
      - RTPENGINE_HOMER_PROTOCOL
      - RTPENGINE_HOMER_ID
      - RTPENGINE_REDIS_ADDRESS
      - RTPENGINE_REDIS_PORT
      - RTPENGINE_REDIS_DB
      - RTPENGINE_REDIS_NUM_THREADS
      - RTPENGINE_RECORDING_DIR
    volumes:
      - rtpengine-logs:/var/log/rtpengine
      - rtpengine-run:/var/run/rtpengine
      - rtpengine-recording:/var/spool/rtpengine
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://127.0.0.1:${RTPENGINE_LISTEN_HTTP:-9101}/ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
    logging:
      driver: gcplogs

volumes:
  rtpengine-logs:
    driver: local
  rtpengine-run:
    driver: local
  rtpengine-recording:
    driver: local
