# RTPEngine Docker Environment Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# DO NOT EDIT MANUALLY - Changes will be overwritten

# Docker Image
RTPENGINE_IMAGE={{ rtpengine_docker_image | default('voipbin/voip-rtpengine') }}:{{ rtpengine_docker_tag | default('latest') }}

# Interface Configuration
# auto: detects IPs from GCP metadata service
RTPENGINE_INTERFACE_MODE={{ rtpengine_interface_mode | default('auto') }}

# HTTP API (health check and metrics)
RTPENGINE_LISTEN_HTTP={{ rtpengine_listen_http | default('9101') }}

# UDP ng Control Protocol (used by Kamailio)
RTPENGINE_LISTEN_NG={{ rtpengine_listen_ng | default('22222') }}

# CLI Interface (for debugging)
RTPENGINE_LISTEN_CLI={{ rtpengine_listen_cli | default('127.0.0.1:2220') }}

# Port Range
RTPENGINE_PORT_MIN={{ rtpengine_port_min | default('20000') }}
RTPENGINE_PORT_MAX={{ rtpengine_port_max | default('65535') }}

# Timeouts
RTPENGINE_TIMEOUT={{ rtpengine_timeout | default('60') }}
RTPENGINE_SILENT_TIMEOUT={{ rtpengine_silent_timeout | default('3600') }}

# Logging
RTPENGINE_LOG_LEVEL={{ rtpengine_log_level | default('6') }}
RTPENGINE_LOG_FACILITY={{ rtpengine_log_facility | default('daemon') }}

# Performance
RTPENGINE_NUM_THREADS={{ rtpengine_num_threads | default('4') }}
RTPENGINE_DELETE_DELAY={{ rtpengine_delete_delay | default('30') }}
RTPENGINE_TOS={{ rtpengine_tos | default('184') }}

# Homer/HEP Integration
RTPENGINE_HOMER_SERVER={{ rtpengine_homer_server | default('') }}
RTPENGINE_HOMER_PROTOCOL={{ rtpengine_homer_protocol | default('udp') }}
RTPENGINE_HOMER_ID={{ rtpengine_homer_id | default('2001') }}

# Redis Session Replication
RTPENGINE_REDIS_ADDRESS={{ rtpengine_redis_address | default('') }}
RTPENGINE_REDIS_PORT={{ rtpengine_redis_port | default('6379') }}
RTPENGINE_REDIS_DB={{ rtpengine_redis_db | default('2') }}
RTPENGINE_REDIS_NUM_THREADS={{ rtpengine_redis_num_threads | default('4') }}

# Recording Configuration
RTPENGINE_RECORDING_DIR={{ rtpengine_recording_dir | default('/var/spool/rtpengine') }}
