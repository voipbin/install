# Kamailio Docker Environment Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# DO NOT EDIT MANUALLY - Changes will be overwritten

# Docker Image
KAMAILIO_IMAGE={{ kamailio_docker_image }}:{{ kamailio_docker_tag }}

# Certificate Path
CERTS_PATH={{ certs_deploy_path }}

# Domain Configuration
BASE_DOMAIN={{ domain }}

# Memory Settings
SHM_SIZE={{ kamailio_shm_size }}
PKG_SIZE={{ kamailio_pkg_size }}

# Kamailio Addresses
KAMAILIO_EXTERNAL_LB_ADDR={{ kamailio_external_lb_ip }}
KAMAILIO_INTERNAL_LB_ADDR={{ kamailio_internal_lb_ip }}
KAMAILIO_INTERNAL_ADDR={{ internal_ip | default(ansible_default_ipv4.address) }}

# Database Configuration
KAMAILIO_AUTH_DB_URL={{ kamailio_auth_db_url }}
KAMAILIO_AUTH_USER_COLUMN={{ kamailio_auth_user_column }}
KAMAILIO_AUTH_DOMAIN_COLUMN={{ kamailio_auth_domain_column }}
KAMAILIO_AUTH_PASSWORD_COLUMN={{ kamailio_auth_password_column }}

# Asterisk Load Balancers
ASTERISK_CALL_LB_ADDR={{ asterisk_call_lb_ip }}:5060
ASTERISK_REGISTRAR_LB_ADDR={{ asterisk_registrar_lb_ip }}:5060
ASTERISK_CONFERENCE_LB_ADDR={{ asterisk_conference_lb_ip }}:5060
ASTERISK_LISTEN_PORT=5060

# RTPEngine
RTPENGINE_SOCKS={{ rtpengine_socks }}

# Monitoring
HOMER_URI={{ homer_uri }}
HOMER_ENABLED={{ homer_enabled }}
REDIS_CACHE_ADDRESS={{ redis_cache_address }}

# Pike anti-flood
PIKE_ENABLED={{ pike_enabled }}
PIKE_RATE={{ pike_rate }}
PIKE_TIMEOUT={{ pike_timeout }}

# Domain name extensions
DOMAIN_NAME_EXTENSION=registrar.{{ domain }}
DOMAIN_NAME_TRUNK=trunk.{{ domain }}

# PSTN Whitelist
PSTN_WHITELIST_IPS={{ pstn_whitelist_ips | default('') }}

# Redis / RabbitMQ
REDIS_URL=redis://:{{ redis_password }}@{{ redis_lb_ip }}:6379/1
RABBITMQ_URL=amqp://{{ rabbitmq_user }}:{{ rabbitmq_password }}@{{ rabbitmq_lb_ip }}:5672

# Kamailio Exporter
KAMAILIO_EXPORTER_IMAGE={{ kamailio_exporter_image }}:{{ kamailio_exporter_tag }}
KAMAILIO_EXPORTER_LISTEN_ADDRESS={{ kamailio_exporter_listen_address }}
KAMAILIO_EXPORTER_METHODS={{ kamailio_exporter_methods }}
