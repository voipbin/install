# Kamailio Docker Compose - generated by Ansible
# DO NOT EDIT MANUALLY - Changes will be overwritten

services:
  # Kamailio SIP proxy
  kamailio:
    image: ${KAMAILIO_IMAGE}
    container_name: kamailio
    restart: unless-stopped
    network_mode: host
    user: root
    cap_add:
      - NET_BIND_SERVICE
    volumes:
      - kamailio-logs:/var/log/kamailio
      - kamailio-run:/run/kamailio
      - ${CERTS_PATH:-./certs}:/certs:ro
    environment:
      # Memory settings
      - SHM_SIZE=${SHM_SIZE:-128}
      - PKG_SIZE=${PKG_SIZE:-128}

      # Domain Configuration
      - BASE_DOMAIN=${BASE_DOMAIN}

      # External addresses
      - KAMAILIO_EXTERNAL_LB_ADDR=${KAMAILIO_EXTERNAL_LB_ADDR}
      - KAMAILIO_INTERNAL_LB_ADDR=${KAMAILIO_INTERNAL_LB_ADDR}
      - KAMAILIO_INTERNAL_ADDR=${KAMAILIO_INTERNAL_ADDR}

      # Database
      - KAMAILIO_AUTH_DB_URL=${KAMAILIO_AUTH_DB_URL}
      - KAMAILIO_AUTH_USER_COLUMN=${KAMAILIO_AUTH_USER_COLUMN:-username}
      - KAMAILIO_AUTH_DOMAIN_COLUMN=${KAMAILIO_AUTH_DOMAIN_COLUMN:-realm}
      - KAMAILIO_AUTH_PASSWORD_COLUMN=${KAMAILIO_AUTH_PASSWORD_COLUMN:-password}

      # Asterisk
      - ASTERISK_CALL_LB_ADDR=${ASTERISK_CALL_LB_ADDR}
      - ASTERISK_REGISTRAR_LB_ADDR=${ASTERISK_REGISTRAR_LB_ADDR}
      - ASTERISK_CONFERENCE_LB_ADDR=${ASTERISK_CONFERENCE_LB_ADDR}
      - ASTERISK_LISTEN_PORT=${ASTERISK_LISTEN_PORT:-5060}

      # RTPEngine
      - RTPENGINE_SOCKS=${RTPENGINE_SOCKS}

      # Monitoring
      - HOMER_URI=${HOMER_URI}
      - HOMER_ENABLED=${HOMER_ENABLED:-false}
      - REDIS_CACHE_ADDRESS=${REDIS_CACHE_ADDRESS}

      # Pike anti-flood
      - PIKE_ENABLED=${PIKE_ENABLED:-true}
      - PIKE_RATE=${PIKE_RATE:-20}
      - PIKE_TIMEOUT=${PIKE_TIMEOUT:-300}

      # PSTN Whitelist
      - PSTN_WHITELIST_IPS=${PSTN_WHITELIST_IPS}

      # Redis / RabbitMQ
      - REDIS_URL=${REDIS_URL}
      - RABBITMQ_URL=${RABBITMQ_URL}
    logging:
      driver: gcplogs

  # Kamailio Prometheus metrics exporter
  kamailio-exporter:
    image: ${KAMAILIO_EXPORTER_IMAGE}
    container_name: kamailio-exporter
    restart: unless-stopped
    network_mode: host
    volumes:
      - kamailio-run:/run/kamailio
    command:
      - "--web.listen-address=${KAMAILIO_EXPORTER_LISTEN_ADDRESS}"
      - "--kamailio.scrape-uri=unix:///run/kamailio/kamailio_ctl"
      - "--kamailio.methods=${KAMAILIO_EXPORTER_METHODS}"
    depends_on:
      kamailio:
        condition: service_healthy
    logging:
      driver: gcplogs

{% if homer_enabled | bool and heplify_lb_ip %}
  # HEP capture client for Homer (PR-U-3)
  # Mirrors production voip-kamailio-docker. Sniffs host-network SIP traffic
  # and forwards HEP packets to the heplify-server internal LoadBalancer at
  # ${HOMER_URI}. Block is gated on (homer_enabled AND heplify_lb_ip) so
  # operators who disable HOMER (or whose LB has not been harvested yet) get
  # NO sidecar in the rendered file, rather than a broken `-hs :9060` arg.
  # depends_on uses short-form list. The kamailio image carries a baked-in
  # HEALTHCHECK (kamailio-exporter relies on `service_healthy` against it),
  # but heplify-client only needs the host interface up — packet capture
  # does not require Kamailio's SIP socket to be fully bound. Short-form
  # `- kamailio` waits for service_started only, which is sufficient.
  heplify-client:
    image: sipcapture/heplify:1.56
    container_name: kamailio-heplify
    restart: unless-stopped
    network_mode: host
    # The sipcapture/heplify:1.56 image leaves ENTRYPOINT empty
    # (CMD defaults to `./heplify -h`). When compose-v2 starts the
    # container, the first element of `command:` is interpreted as the
    # executable. Without an explicit entrypoint, `-i` would be treated
    # as the program to exec, producing
    #   exec: "-i": executable file not found in $PATH
    # at runtime (caught in v6 dogfood iteration #5). Pin the executable
    # via `entrypoint:` so `command:` carries only flags, matching the
    # production voip-kamailio-docker pattern.
    entrypoint: ["./heplify"]
    command:
      - "-i"
      - "any"
      - "-hs"
      - "${HOMER_URI}"
      - "-m"
      - "SIP"
      - "-dim"
      - "REGISTER"
    depends_on:
      - kamailio
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "2"
{% endif %}

volumes:
  kamailio-logs:
    driver: local
  kamailio-run:
    driver: local
